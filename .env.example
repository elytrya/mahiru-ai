# ==== Telegram ====
BOT_TOKEN=
ADMIN_IDS=

# ==== DB / cache ====
DATABASE_URL=sqlite+aiosqlite:///./mahiru.db
# DATABASE_URL=postgresql+asyncpg://mahiru:mahiru@postgres:5432/mahiru
REDIS_URL=redis://localhost:6379/0

# ==== AI ====
# gemini | openai | claude | deepseek | ollama | g4f
DEFAULT_PROVIDER=g4f

# --- Gemini ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# --- OpenAI ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Claude ---
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-3-5-sonnet-latest

# --- DeepSeek ---
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# --- Ollama ---
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.1

# --- g4f (gpt4free) --- бесплатный доступ, ключи не нужны
G4F_MODEL=gpt-4o-mini
G4F_PROVIDER=

# ==== Tools ====
GOOGLE_API_KEY=
GOOGLE_CX=

# ==== Autonomous ====
AUTONOMOUS_ENABLED=true
AUTONOMOUS_MIN_HOURS=3
AUTONOMOUS_MAX_HOURS=12
AUTONOMOUS_TIME_START=10
AUTONOMOUS_TIME_END=23

LOG_LEVEL=INFO
