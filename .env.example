# ==== Telegram ====
BOT_TOKEN=
ADMIN_IDS=

# ==== DB / cache ====
DATABASE_URL=sqlite+aiosqlite:///./mahiru.db
# DATABASE_URL=postgresql+asyncpg://mahiru:mahiru@postgres:5432/mahiru
REDIS_URL=redis://localhost:6379/0

# ==== AI ====
# gemini | openai | claude | deepseek | ollama | g4f
DEFAULT_PROVIDER=g4f

# --- Gemini ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# --- OpenAI ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Claude ---
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-3-5-sonnet-latest

# --- DeepSeek ---
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# --- Ollama ---
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.1

# --- g4f (gpt4free) --- бесплатный доступ, ключи не нужны
G4F_MODEL=gpt-4o-mini
G4F_PROVIDER=

# ==== Tools ====
GOOGLE_API_KEY=
GOOGLE_CX=
# OpenWeather (погода-забота). Ключ: https://openweathermap.org/api
OPENWEATHER_API_KEY=

# ==== Погода-забота (OpenWeather) ====
# Сама напишет «там у тебя дождь, возьми зонт» (нужен ключ и город)
# Про погоду она вспоминает САМА, когда захочет — без часов и расписания.
WEATHER_ENABLED=true
# Город, где ты живёшь (напр. Москва). Можно задать в Telegram: /weather city <город>
WEATHER_CITY=
# metric = °C, imperial = °F
WEATHER_UNITS=metric
WEATHER_LANG=ru
# Город, где "живёт" сама Махиру (учёба/быт/своя погода). Может рассказывать про погоду у себя
MAHIRU_CITY=Токио

# ==== Характер: ревность / энергия / близость / пет-неймы ====
# Ревность/обидки: если долго не писал - встречает с лёгкой обидой
JEALOUSY_ENABLED=true
# Сколько часов молчания, чтобы начала обижаться
JEALOUSY_HOURS=12
# Энергия/батарейка: к ночи «устаёт», сообщения короче и мягче
ENERGY_ENABLED=true
# Уровень близости: копится со временем, разблокирует более тёплый тон
CLOSENESS_ENABLED=true
# На сколько растёт близость за каждое сообщение
CLOSENESS_PER_MSG=1
# Клички/пет-неймы: сама придумывает ласковое прозвище
PETNAMES_ENABLED=true
# При какой близости придумает прозвище
PETNAME_THRESHOLD=30

# ==== Живые реакции / опечатки / настроение ====
# Эмодзи-реакции на сообщения (set_message_reaction)
REACTIONS_ENABLED=true
REACTION_CHANCE=0.25
# Опечатки с самоисправлением (следующим сообщением "*то есть")
TYPO_ENABLED=true
TYPO_CHANCE=0.12
# Настроение влияет на скорость/тон
MOOD_SPEED_ENABLED=true
# "Прочитала, но молчит пару минут"
READ_SILENCE_ENABLED=true
READ_SILENCE_CHANCE=0.07
READ_SILENCE_MIN_SECONDS=45
READ_SILENCE_MAX_SECONDS=150

# ==== Стикеры / памятные даты ====
# Стикеры/кастом-эмодзи по настроению (управление набором — команда /sticker)
STICKERS_ENABLED=true
STICKER_CHANCE=0.15
# ID через запятую. Чисто цифровой = кастом-эмодзи (премиум), с буквами (CAAC...) = file_id стикера
STICKER_IDS_DEFAULT=6365185259734040633
# Памятные даты: в свой день сама поздравит, когда захочет (управление — команда /date)
DATES_ENABLED=true

# ==== Инициатива: она САМА решает, когда писать первой / глянуть на экран ====
# БОЛЬШЕ НЕТ окон по часам, НЕТ «шансов» и НЕТ лимита «N раз в день».
# Каждые INITIATIVE_TICK_MINUTES минут она смотрит на контекст и сама решает: хочет — напишет/глянет, не хочет — молчит.
AUTONOMOUS_ENABLED=true
# Как часто она получает «возможность» проявить инициативу (минуты)
INITIATIVE_TICK_MINUTES=20
# Мягкий предохранитель от спама: не проявлять инициативу чаще, чем раз в N минут (НЕ расписание)
INITIATIVE_MIN_GAP_MINUTES=40

# ==== Смотрит на экран (screen watch) ====
# Махиру САМА, когда захочет (по контексту), заглядывает на твой экран и комментирует.
# Никаких окон по часам и лимитов — только её желание. Также можно попросить «глянь на экран».
# НУЖЕН AI-провайдер с поддержкой картинок (gemini, openai gpt-4o, g4f с vision и т.п.).
# Снимок делается на машине, где ЗАПУЩЕН бот. Управление — команда /screen.
SCREEN_WATCH_ENABLED=false
# Какой монитор снимать: 0 = все сразу, 1 = первый, 2 = второй...
SCREEN_WATCH_MONITOR=0
# Сжатие скриншота перед отправкой в модель
SCREEN_WATCH_MAX_WIDTH=1280
SCREEN_WATCH_JPEG_QUALITY=70

LOG_LEVEL=INFO
